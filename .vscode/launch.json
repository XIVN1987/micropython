{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ARMDbg",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "arm",
            "MIMode": "gdb",
            "miDebuggerPath": "C:/Ubuntu/bin/gcc-arm-win/bin/arm-none-eabi-gdb.exe",
            "program": "C:/Ubuntu/micropython-dev/ports/m480/build-M482Lite/micropython.elf",
            "cwd": "C:/Ubuntu/micropython-dev/ports/m480",
            "externalConsole": true,
            "setupCommands": [
                {
                    "text": "exec-file 'C:/Ubuntu/micropython-dev/ports/m480/build-M482Lite/micropython.elf'"
                },
                {
                    "text": "target remote localhost:2331"
                },
                {
                    "text": "monitor reset"
                },
                {
                    "text": "monitor halt"
                },
                {
                    "text": "load"
                }
            ]
        }
    ]
}
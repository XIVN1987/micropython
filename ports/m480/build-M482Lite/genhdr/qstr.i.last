static inline void enable_irq(mp_uint_t state) {

    __asm volatile ("MSR primask, %0" : : "r" (state) : "memory");
}

static inline mp_uint_t disable_irq(void) {

    mp_uint_t state;
    __asm volatile ("MRS %0, primask" : "=r" (state) );


    __asm volatile ("cpsid i" : : : "memory");

    return state;
}
